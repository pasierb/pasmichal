---
import Layout from "./main.astro";
const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title + " | Michal Pasierbski"}>
  <Fragment slot="meta-tags">
    <!-- Primary Meta Tags -->
    <meta name="title" content={frontmatter.title} />
    <meta name="description" content={frontmatter.description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content={new URL(Astro.url.pathname, Astro.url).href}
    />
    <meta property="og:title" content={frontmatter.title} />
    <meta property="og:description" content={frontmatter.description} />
    {
      frontmatter.heroImage && (
        <meta
          property="og:image"
          content={new URL(frontmatter.heroImage, Astro.url).href}
        />
      )
    }

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta
      property="twitter:url"
      content={new URL(Astro.url.pathname, Astro.url).href}
    />
    <meta property="twitter:title" content={frontmatter.title} />
    <meta property="twitter:description" content={frontmatter.description} />
    {
      frontmatter.heroImage && (
        <meta
          property="twitter:image"
          content={new URL(frontmatter.heroImage, Astro.url).href}
        />
      )
    }
  </Fragment>

  <main class="relative z-30 max-w-4xl mx-auto mt-10 md:mt-20">
    <slot name="before-content" />

    <article
      class="w-full max-w-2xl mx-auto mb-20 prose-sm prose px-7 lg:px-0 lg:prose-lg dark:prose-invert"
    >
      {
        frontmatter.heroImage && (
          <div class="w-full rounded-xl overflow-hidden">
            <img
              src={frontmatter.heroImage}
              alt={frontmatter.title}
              class="w-full h-full object-cover"
            />
          </div>
        )
      }

      <h1
        class="w-full max-w-2xl mx-auto text-3xl font-bold leading-tight tracking-tighter text-left md:mb-12 md:text-4xl text-primary dark:text-primary-dark lg:text-5xl md:leading-none"
      >
        {frontmatter.title}
      </h1>

      <slot />
    </article>
  </main>
</Layout>
