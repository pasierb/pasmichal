---
import Layout from "./main.astro";
const { title, description = "" } = Astro.props;
---

<Layout title={title + " | Michal Pasierbski"}>
  <Fragment slot="meta-tags">
    <!-- Primary Meta Tags -->
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content={new URL(Astro.url.pathname, Astro.url).href}
    />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta
      property="twitter:url"
      content={new URL(Astro.url.pathname, Astro.url).href}
    />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
  </Fragment>

  <main class="relative z-30 max-w-4xl mx-auto mt-10 md:mt-20">
    <slot name="before-content" />

    <article class="w-full max-w-2xl mx-auto mb-20 px-7">
      <h1
        class="w-full max-w-2xl mx-auto text-3xl font-bold leading-tight tracking-tighter text-left md:mb-12 md:text-4xl text-primary dark:text-primary-dark lg:text-5xl md:leading-none"
      >
        {title}
      </h1>

      <slot />
    </article>
  </main>
</Layout>
