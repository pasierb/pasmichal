---
const { logo, dates, role, company, description } = Astro.props;
---

<div class="relative flex flex-col justify-start pl-12">
  <div
    class="absolute top-0 left-0 z-40 flex items-center justify-center -translate-x-1/2 bg-surface border rounded-full w-14 h-14 border-border dark:border-border-dark"
  >
    <img src={logo} alt={company} class="w-8 max-h-8" />
  </div>

  <p
    class="text-sm uppercase text-secondary dark:text-secondary-dark tracking-widest"
  >
    {dates}
  </p>
  <h3 class="my-1 text-xl font-bold text-primary dark:text-primary-dark">{role}</h3>
  <p class="mb-1 font-medium text-primary dark:text-primary-dark">{company}</p>
  {
    Array.isArray(description) ? (
      <ul class="mb-1 space-y-1">
        {description.map((item) => (
          <li class="text-sm font-light text-secondary dark:text-secondary-dark">• {item}</li>
        ))}
      </ul>
    ) : (
      <p class="text-sm font-light text-secondary dark:text-secondary-dark">
        {description}
      </p>
    )
  }
</div>
