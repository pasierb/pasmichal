---
const { title, description } = Astro.props;
---

<section class="max-w-4xl mx-auto px-7 lg:px-0 mb-16">
  <h2
    class="text-2xl font-bold leading-10 tracking-tight text-primary dark:text-primary-dark"
  >
    {title}
  </h2>
  <p class="mb-6 text-base text-secondary dark:text-secondary-dark">
    {description}
  </p>
  <div class="w-full mt-7">
    <slot />
  </div>

  <div class="flex items-center justify-center w-full py-5">
    <slot name="buttons" />
  </div>
</section>
