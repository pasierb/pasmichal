---
import SocialLinks from "../components/social-links.astro";
---

<footer class="max-w-4xl mx-auto px-7 lg:px-0 py-12 border-t border-border dark:border-border-dark">
  <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
    <div class="flex items-center gap-3 text-sm text-muted dark:text-muted-dark">
      <a href="/" class="font-bold text-primary dark:text-primary-dark">MP</a>
      <span>&copy; {new Date().getFullYear()}</span>
    </div>
    <div class="flex items-center gap-4">
      <SocialLinks />
    </div>
  </div>
</footer>
