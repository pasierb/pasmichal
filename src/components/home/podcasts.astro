---
import { getCollection } from "astro:content";
const allAppearances = await getCollection("podcast");

const sorted = allAppearances.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const monthFormat = new Intl.DateTimeFormat("en-US", {
  month: "short",
  year: "numeric",
});
---

<section class="max-w-4xl mx-auto px-7 lg:px-0 mb-20">
  <div class="flex items-baseline justify-between mb-10">
    <h2 class="text-xl font-semibold text-primary dark:text-primary-dark">
      Podcasts & Talks
    </h2>
    <a
      href="/podcast"
      class="text-sm text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-colors"
    >
      View all ({allAppearances.length})
    </a>
  </div>
  <div class="divide-y divide-border dark:divide-border-dark">
    {
      sorted.map((appearance) => (
        <a
          href={`/podcast/${appearance.id}`}
          class="flex items-baseline gap-8 py-5 group transition-colors"
        >
          <span class="text-sm text-muted dark:text-muted-dark w-24 flex-shrink-0">
            {monthFormat.format(new Date(appearance.data.date))}
          </span>
          <span class="text-base text-primary dark:text-primary-dark group-hover:text-secondary dark:group-hover:text-secondary-dark transition-colors">
            {appearance.data.title}
          </span>
        </a>
      ))
    }
  </div>
</section>
