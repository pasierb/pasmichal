---
import { projects } from "../../collections/projects";
import Project from "../project.astro";

const activeProjects = projects.filter(p => p.featured);
---

<section class="max-w-4xl mx-auto px-7 lg:px-0 mb-20">
  <div class="flex items-baseline justify-between mb-10">
    <h2 class="text-xl font-semibold text-primary dark:text-primary-dark">
      Latest Projects
    </h2>
    <a
      href="/projects"
      class="text-sm text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-colors"
    >
      View all projects ({projects.length})
    </a>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
    {
      activeProjects.map((project) => (
        <Project
          name={project.name}
          description={project.description}
          imageAsset={project.imageAsset}
          status={project.status}
          url={project.url}
          techStack={project.techStack}
        />
      ))
    }
  </div>
</section>
