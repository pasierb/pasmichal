---
interface Props {
  name: string;
  description: string;
  url: string;
  image: string;
  status: string;
  techStack?: string[];
}

const { name, description, url, image, status, techStack = [] } = Astro.props;
---

<a
  href={status === "active" ? url : "#"}
  target="_blank"
  class="group block"
>
  <div class="relative overflow-hidden rounded-2xl">
    <img
      src={image}
      alt={name}
      class="w-full h-auto aspect-[16/10] object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>
  <div class="mt-4">
    <h3 class="text-base font-semibold text-primary dark:text-primary-dark group-hover:text-secondary dark:group-hover:text-secondary-dark transition-colors">
      {name}
    </h3>
    <p class="mt-1 text-sm text-muted dark:text-muted-dark line-clamp-2">
      {description}
    </p>
    {techStack.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1.5">
        {techStack.map((tech) => (
          <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-muted dark:text-muted-dark">
            {tech}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
