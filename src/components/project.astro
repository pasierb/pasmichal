---
const { name, description, url, image, status } = Astro.props;
---

<a
  href={status === "active" ? url : "#"}
  target="_blank"
  class="group block"
>
  <div class="relative overflow-hidden rounded-2xl">
    <img
      src={image}
      alt={name}
      class="w-full h-auto aspect-[16/10] object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>
  <div class="mt-4">
    <h3 class="text-base font-semibold text-primary dark:text-primary-dark group-hover:text-secondary dark:group-hover:text-secondary-dark transition-colors">
      {name}
    </h3>
    <p class="mt-1 text-sm text-muted dark:text-muted-dark line-clamp-2">
      {description}
    </p>
  </div>
</a>
