---
import menus from "../collections/menu.json";
import Logo from "../components/logo.astro";
---

<div class="relative w-full h-16 opacity-0 pointer-events-none"></div>
<header id="header" class="absolute top-0 z-50 w-full h-16">
  <div
    class="flex items-center justify-between h-full max-w-4xl px-7 mx-auto"
  >
    <!-- Left: Logo | nav -->
    <div class="flex items-center gap-6">
      <Logo />
      <nav class="hidden sm:flex items-center gap-1">
        {
          menus.map((menu) => (
            <a
              href={menu.url}
              class="px-3 py-1.5 text-sm text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark transition-colors duration-200"
            >
              {menu.name}
            </a>
          ))
        }
      </nav>
    </div>

    <!-- Right: Social icons | dark mode -->
    <div class="flex items-center gap-4">
      <div class="hidden sm:flex items-center gap-3">
        <a
          href="https://x.com/pasmichal_"
          target="_blank"
          class="text-muted dark:text-muted-dark hover:text-primary dark:hover:text-primary-dark transition-colors"
          aria-label="X (Twitter)"
        >
          <svg class="w-[15px] h-[15px]" viewBox="0 0 24 24" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
          </svg>
        </a>
        <a
          href="https://linkedin.com/in/mpasierbski"
          target="_blank"
          class="text-muted dark:text-muted-dark hover:text-primary dark:hover:text-primary-dark transition-colors"
          aria-label="LinkedIn"
        >
          <svg class="w-[15px] h-[15px]" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
          </svg>
        </a>
        <a
          href="mailto:hello@pasierbski.com"
          class="text-muted dark:text-muted-dark hover:text-primary dark:hover:text-primary-dark transition-colors"
          aria-label="Email"
        >
          <svg class="w-[15px] h-[15px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </a>
      </div>

      <div class="hidden sm:block w-px h-4 bg-border dark:bg-border-dark"></div>

      <div
        id="darkToggle"
        class="flex items-center justify-center w-8 h-8 cursor-pointer text-muted dark:text-muted-dark hover:text-primary dark:hover:text-primary-dark transition-colors"
      >
        <svg
          class="w-[15px] h-[15px] transition duration-700 transform ease"
          id="sun"
          fill="none"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"></path>
        </svg>
        <svg
          class="hidden w-[15px] h-[15px] transition duration-700 transform ease"
          id="moon"
          fill="none"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
        </svg>
        <span class="hidden">
          <span id="dayText">Day mode</span>
          <span id="nightText" class="hidden">Night mode</span>
        </span>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobileMenuBtn"
        class="sm:hidden flex items-center justify-center w-8 h-8 text-secondary dark:text-secondary-dark"
        aria-label="Toggle menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 8h16M4 16h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <nav
    id="mobileMenu"
    class="hidden sm:hidden bg-surface dark:bg-surface-dark border-t border-border dark:border-border-dark px-7 pb-4 pt-2"
  >
    {
      menus.map((menu) => (
        <a
          href={menu.url}
          class="block py-2 text-sm text-secondary dark:text-secondary-dark hover:text-primary dark:hover:text-primary-dark"
        >
          {menu.name}
        </a>
      ))
    }
    <div class="flex items-center gap-4 pt-3 mt-2 border-t border-border dark:border-border-dark">
      <a href="https://x.com/pasmichal_" target="_blank" class="text-muted dark:text-muted-dark hover:text-primary dark:hover:text-primary-dark transition-colors" aria-label="X">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
      </a>
      <a href="https://linkedin.com/in/mpasierbski" target="_blank" class="text-muted dark:text-muted-dark hover:text-primary dark:hover:text-primary-dark transition-colors" aria-label="LinkedIn">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path></svg>
      </a>
      <a href="mailto:hello@pasierbski.com" class="text-muted dark:text-muted-dark hover:text-primary dark:hover:text-primary-dark transition-colors" aria-label="Email">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
      </a>
    </div>
  </nav>
</header>

<script is:inline>
  document.getElementById('mobileMenuBtn')?.addEventListener('click', () => {
    document.getElementById('mobileMenu')?.classList.toggle('hidden');
  });
</script>
