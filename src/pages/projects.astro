---
import { projects, featuredProjects } from "../collections/projects";
import Project from "../components/project.astro";
import Layout from "../layouts/main.astro";

const allProjects = projects;
---

<Layout title="My Projects | Michal Pasierbski">
  <section class="max-w-4xl mx-auto mt-20 px-7 md:mt-28 lg:mt-36 lg:px-0 mb-24">
    <h1
      class="text-4xl md:text-5xl lg:text-6xl font-bold leading-[0.95] tracking-tight text-primary dark:text-primary-dark"
    >
      Projects
    </h1>
    <p class="mt-6 text-base leading-relaxed text-secondary dark:text-secondary-dark max-w-2xl">
      Here are some of the projects I've been working on. I'm always building something new.
    </p>

    <div
      class="grid items-stretch w-full grid-cols-1 mt-16 gap-8 sm:grid-cols-2"
    >
      {
        featuredProjects.map((project) => (
          <Project
            name={project.name}
            description={project.description}
            image={project.image}
            url={project.url}
            status={project.status}
            techStack={project.techStack}
          />
        ))
      }
    </div>

    {allProjects.length > 0 && (
      <div class="mt-16">
        <h2 class="text-2xl font-bold text-primary dark:text-primary-dark">All Projects</h2>
        <ul class="mt-6 divide-y divide-gray-200 dark:divide-gray-700">
          {allProjects.map((project) => (
            <li class="py-4">
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="group flex items-center justify-between"
              >
                <div>
                  <span class="text-lg font-medium text-primary dark:text-primary-dark group-hover:underline">
                    {project.name} {project.status !== "active" && <span class="font-normal text-secondary dark:text-secondary-dark">({project.status})</span>}
                  </span>
                  <p class="mt-1 text-sm text-secondary dark:text-secondary-dark">
                    {project.description}
                  </p>
                  {project.techStack.length > 0 && (
                    <div class="mt-2 flex flex-wrap gap-1.5">
                      {project.techStack.map((tech) => (
                        <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-primary dark:text-primary-dark">
                          {tech}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
                <svg
                  class="w-5 h-5 flex-shrink-0 ml-4 text-secondary dark:text-secondary-dark group-hover:text-primary dark:group-hover:text-primary-dark transition-colors"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 17L17 7M17 7H7M17 7v10" />
                </svg>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
</Layout>
