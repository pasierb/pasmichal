---
import Projects from "../components/home/projects.astro";
import Writings from "../components/home/writings.astro";
import Podcasts from "../components/home/podcasts.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="Michal Pasierbski">
  <div class="w-full max-w-4xl mx-auto mt-20 px-7 md:mt-28 lg:mt-36 xl:px-0 mb-24">
    <h1
      class="text-5xl md:text-7xl lg:text-8xl font-bold leading-[0.95] tracking-tight text-primary dark:text-primary-dark"
    >
      Michal<br />Pasierbski
    </h1>
    <div class="mt-8 flex flex-wrap items-center justify-between gap-y-2 text-sm">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-secondary dark:text-secondary-dark">
        <span class="font-medium text-primary dark:text-primary-dark">Software Engineer</span>
        <span class="text-border dark:text-border-dark">&bull;</span>
        <span>AI Practitioner</span>
        <span class="text-border dark:text-border-dark">&bull;</span>
        <span>Builder</span>
      </div>
      <div class="flex items-center gap-1.5 text-muted dark:text-muted-dark">
        <span>📍</span>
        <span>Zurich, Switzerland</span>
      </div>
    </div>
    <p class="mt-6 text-base leading-relaxed text-secondary dark:text-secondary-dark max-w-2xl">
      I've spent 15+ years solving problems with software — across startups, big tech, and everything in between. Father, husband, and someone who can't stop tinkering. I believe the best code is the code you don't write.
    </p>
  </div>

  <Projects />
  <Writings />
  <Podcasts />
</Layout>
