---
import Projects from "../components/home/projects.astro";
import Writings from "../components/home/writings.astro";
import Podcasts from "../components/home/podcasts.astro";
import Layout from "../layouts/main.astro";
---

<Layout title="Michal Pasierbski">
  <div class="w-full px-7 md:px-12 lg:px-16 mt-20 md:mt-28 lg:mt-36">
    <h1 class="text-[clamp(3rem,12vw,14rem)] font-extrabold uppercase leading-[0.9] tracking-tighter text-primary dark:text-primary-dark">
      Michal Pasierbski
    </h1>
  </div>

  <div class="w-full px-7 md:px-12 lg:px-16 mt-6 md:mt-8">
    <hr class="border-t border-border dark:border-border-dark" />
  </div>

  <div class="w-full px-7 md:px-12 lg:px-16 mt-4 md:mt-6">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-y-2 text-sm text-secondary dark:text-secondary-dark">
      <span>Software Engineer</span>
      <span>Zurich, Switzerland</span>
      <span>Independent Builder</span>
    </div>
  </div>

  <div class="w-full px-7 md:px-12 lg:px-16 mt-10 md:mt-14 mb-24">
    <p class="text-center text-lg md:text-xl lg:text-2xl leading-relaxed text-secondary dark:text-secondary-dark max-w-3xl mx-auto">
      [I've spent 15+ years solving problems with software — across startups, big techs 
      <img src="/assets/images/experiences/google.svg" alt="Google" class="inline-block align-middle h-5 md:h-6 mx-1" />
      <img src="/assets/images/experiences/aws.svg" alt="AWS" class="inline-block align-middle h-5 md:h-6 mx-1" />,
      and everything in between. I believe the best code is the code you don't write.]
    </p>
  </div>

  <Projects />
  <Writings />
  <Podcasts />
</Layout>
